# OpenAI (LLM y embeddings para RAG). Obligatorio.
OPENAI_API_KEY=sk-...

# Tavily (búsqueda web para el agente). Obligatorio para el Paso 5 de verificación.
TAVILY_API_KEY=tvly-...

# Modelo LLM (opcional; por defecto gpt-5-nano)
MODEL_NAME=gpt-5-nano

# Modelo de embeddings para RAG (opcional; por defecto text-embedding-3-small)
EMBEDDING_MODEL=text-embedding-3-small

# PostgreSQL: checkpointer, store y PGVector. Levantar con: docker-compose up -d
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/postgres

# RAG: nombre de la colección de vectores en Postgres (opcional)
RAG_COLLECTION_NAME=soporte_docs

# Ruta a la carpeta de documentos para indexar (opcional; por defecto "docs")
DOCS_PATH=docs
