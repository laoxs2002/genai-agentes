# OpenAI (obligatorio)
# API key para modelos GPT y embeddings
OPENAI_API_KEY=sk-...

# Tavily (obligatorio para búsqueda web)
# Obtener en https://tavily.com - plan gratuito disponible
TAVILY_API_KEY=tvly-...

# LangSmith (opcional)
# Plataforma de observabilidad para agentes
# Obtener en https://smith.langchain.com
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2-...
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
